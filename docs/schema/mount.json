{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/lucasassuncao/devcontainerwizard/internal/model/mount",
  "properties": {
    "type": {
      "type": "string",
      "description": "Type of mount: bind, volume, or tmpfs."
    },
    "source": {
      "type": "string",
      "description": "Source path or volume name. Not required for tmpfs mounts."
    },
    "target": {
      "type": "string",
      "description": "Target path inside the container."
    },
    "readonly": {
      "type": "boolean",
      "description": "Whether the mount is read-only."
    }
  },
  "additionalProperties": false,
  "type": "object",
  "required": [
    "type",
    "target"
  ]
}
